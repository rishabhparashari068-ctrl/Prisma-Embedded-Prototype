# Server Config
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:5173,https://prismaembedded.codes,https://www.prismaembedded.codes

# Database Config (PostgreSQL)
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL="postgresql://postgres:your_postgres_password@localhost:5432/prisma_auth?schema=public"
DATABASE_REPLICA_URL="postgresql://postgres:your_postgres_password@localhost:5432/prisma_auth?schema=public"

# Redis Config
REDIS_PASSWORD=your_redis_password
REDIS_URL="redis://:your_redis_password@localhost:6379/0"

# JWT - RS256 keys generated by `node generate-keys.js`.
# These are base64-encoded DER private/public key values.
JWT_PRIVATE_KEY=insert_secure_jwt_private_key_here
JWT_PUBLIC_KEY=insert_secure_jwt_public_key_here
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# CSRF Secret (64-char random hex string)
CSRF_SECRET=insert_secure_hex_key_here

# Resend Email Config
RESEND_API_KEY=insert_resend_api_key_here
EMAIL_FROM=no-reply@your-verified-domain.com
FRONTEND_URL=http://localhost:5173

# OAuth Credentials
GOOGLE_CLIENT_ID=insert_google_client_id_here
GOOGLE_CLIENT_SECRET=insert_google_client_secret_here
GITHUB_CLIENT_ID=insert_github_client_id_here
GITHUB_CLIENT_SECRET=insert_github_client_secret_here

# AI Resume Reviewer (backend only; never use a VITE_ prefix)
GROQ_API_KEY=insert_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Local bootstrap admin. Required when bootstrapping the admin user.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password
ADMIN_FULL_NAME=System Administrator

# Sensitive field encryption key (32-byte hex key for encrypting secrets like OAuth tokens)
FIELD_ENCRYPTION_KEY=insert_secure_hex_key_here

# Security Hardening
BCRYPT_ROUNDS=12
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION_MINUTES=30
