datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  super_admin
  admin
  team_leader
  team_member
  user
  student
  mentor
  recruiter
}

enum TokenType {
  email_verification
  password_reset
  email_change
  account_unlock
}

model User {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String         @unique
  emailVerified      Boolean        @default(false) @map("email_verified")
  fullName           String         @map("full_name")
  avatarUrl          String?        @map("avatar_url")
  role               UserRole       @default(student)
  passwordHash       String?        @map("password_hash")
  mfaSecret          String?        @map("mfa_secret")
  mfaEnabled         Boolean        @default(false) @map("mfa_enabled")
  mfaRecoveryCodes   String[]       @map("mfa_recovery_codes")
  failedAttempts     Int            @default(0) @db.SmallInt @map("failed_attempts")
  lockedUntil        DateTime?      @map("locked_until")
  lastLoginAt        DateTime?      @map("last_login_at")
  lastLoginIp        String?        @db.Inet @map("last_login_ip")
  metadata           Json           @default("{}")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  refreshTokens      RefreshToken[]
  oauthAccounts      OAuthAccount[]
  authTokens         AuthToken[]
  auditLogs          AuditLog[]

  teamMemberships    TeamMember[]
  sentInvitations    TeamInvitation[] @relation("SentInvitations")
  ownedProjects      Project[]        @relation("OwnedProjects")
  assignedTasks      Task[]           @relation("AssignedTasks")
  createdTasks       Task[]           @relation("CreatedTasks")
  taskComments       TaskComment[]
  createdDocuments   SharedDocument[]
  uploadedFiles      SharedFile[]
  sentMessages       ChatMessage[]    @relation("SentMessages")
  receivedMessages   ChatMessage[]    @relation("ReceivedMessages")
  createdCatalogCourses CatalogCourse[] @relation("CreatedCatalogCourses")
  createdCatalogProjects CatalogProject[] @relation("CreatedCatalogProjects")

  @@map("users")
}

model CatalogCourse {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String   @unique
  title        String
  subtitle     String
  description  String
  syllabus     String[]
  duration     String
  rating       Float    @default(0)
  modulesCount Int      @default(1) @map("modules_count")
  badge        String?
  accent       String   @default("indigo")
  actionUrl    String?  @map("action_url")
  published    Boolean  @default(true)
  creatorId    String   @db.Uuid @map("creator_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  creator User @relation("CreatedCatalogCourses", fields: [creatorId], references: [id], onDelete: Restrict)

  @@index([published, createdAt])
  @@map("catalog_courses")
}

model CatalogProject {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String   @unique
  title       String
  category    String
  tier        String
  description String
  price       Int      @default(0)
  popular     Boolean  @default(false)
  free        Boolean  @default(false)
  actionUrl   String?  @map("action_url")
  published   Boolean  @default(true)
  creatorId   String   @db.Uuid @map("creator_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  creator User @relation("CreatedCatalogProjects", fields: [creatorId], references: [id], onDelete: Restrict)

  @@index([published, category, tier])
  @@map("catalog_projects")
}

model RefreshToken {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @db.Uuid @map("user_id")
  tokenHash     String    @unique @map("token_hash")
  family        String    @db.Uuid
  deviceInfo    Json?     @map("device_info")
  expiresAt     DateTime  @map("expires_at")
  revoked       Boolean   @default(false)
  revokedAt     DateTime? @map("revoked_at")
  revokedReason String?   @map("revoked_reason")
  createdAt     DateTime  @default(now()) @map("created_at")

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revoked])
  @@index([family])
  @@map("refresh_tokens")
}

model OAuthAccount {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @db.Uuid @map("user_id")
  provider     String
  providerId   String    @map("provider_id")
  accessToken  String?   @map("access_token")
  refreshToken String?   @map("refresh_token")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model AuthToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid @map("user_id")
  tokenHash String    @unique @map("token_hash")
  type      TokenType
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  ipAddress String?   @db.Inet @map("ip_address")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    String?  @db.Uuid @map("user_id")
  action    String
  resource  String?
  ipAddress String?  @db.Inet @map("ip_address")
  userAgent String?  @map("user_agent")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Team {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  members     TeamMember[]
  projects    Project[]
  invitations TeamInvitation[]
  chatMessages ChatMessage[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId    String   @db.Uuid @map("team_id")
  userId    String   @db.Uuid @map("user_id")
  role      String   @default("MEMBER")
  createdAt DateTime @default(now()) @map("created_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model TeamInvitation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId       String   @db.Uuid @map("team_id")
  inviterId    String   @db.Uuid @map("inviter_id")
  inviteeEmail String   @map("invitee_email")
  role         String   @default("MEMBER")
  status       String   @default("PENDING")
  createdAt    DateTime @default(now()) @map("created_at")

  team    Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  inviter User @relation("SentInvitations", fields: [inviterId], references: [id], onDelete: Cascade)

  @@map("team_invitations")
}

model Project {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId      String?          @db.Uuid @map("team_id")
  ownerId     String           @db.Uuid @map("owner_id")
  title       String
  description String?
  difficulty  String           @default("Beginner")
  track       String           @default("Web Dev")
  status      String           @default("ACTIVE")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  team         Team?            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  owner        User             @relation("OwnedProjects", fields: [ownerId], references: [id], onDelete: Cascade)
  tasks        Task[]
  documents    SharedDocument[]
  files        SharedFile[]
  chatMessages ChatMessage[]

  @@map("projects")
}

model Task {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String        @db.Uuid @map("project_id")
  title       String
  description String?
  status      String        @default("TO_DO")
  priority    String        @default("MEDIUM")
  assigneeId  String?       @db.Uuid @map("assignee_id")
  creatorId   String        @db.Uuid @map("creator_id")
  dueDate     DateTime?     @map("due_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?         @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User          @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: Cascade)
  comments TaskComment[]

  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId    String   @db.Uuid @map("task_id")
  userId    String   @db.Uuid @map("user_id")
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model SharedDocument {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @db.Uuid @map("project_id")
  title       String
  content     String
  creatorId   String   @db.Uuid @map("creator_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@map("shared_documents")
}

model SharedFile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String   @db.Uuid @map("project_id")
  name        String
  url         String
  size        Int
  mimeType    String   @map("mime_type")
  uploaderId  String   @db.Uuid @map("uploader_id")
  createdAt   DateTime @default(now()) @map("created_at")

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User    @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@map("shared_files")
}

model ChatMessage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId         String?  @db.Uuid @map("team_id")
  projectId      String?  @db.Uuid @map("project_id")
  senderId       String   @db.Uuid @map("sender_id")
  receiverId     String?  @db.Uuid @map("receiver_id")
  content        String
  isAnnouncement Boolean  @default(false) @map("is_announcement")
  createdAt      DateTime @default(now()) @map("created_at")

  team     Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project  Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender   User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User?    @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}
